# Пример файла переменных окружения
# Скопируйте этот файл в .env и настройте под ваше окружение:
# cp .env.example .env

# === Backend Configuration ===
BACKEND_PORT=8080

# === Nginx Configuration ===
NGINX_VERSION=alpine
NGINX_HOST_PORT=80

# === Network Configuration ===
NETWORK_NAME=effective-mobile-network

# === Application Configuration ===
APP_ENV=production
LOG_LEVEL=info