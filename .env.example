# Пример файла переменных окружения
# Скопируйте этот файл в .env и настройте под ваше окружение:
# cp .env.example .env

# === Backend Configuration ===
BACKEND_PORT=8080

# === Nginx Configuration ===
NGINX_HOST_PORT=80
BACKEND_SERVICE=backend

# === Network Configuration ===
NETWORK_NAME=eldabaof-network

# === Application Configuration ===
LOG_LEVEL=info